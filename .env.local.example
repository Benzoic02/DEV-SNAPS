# =====================================================
# DevSnaps Environment Variables
# =====================================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to version control!

# =====================================================
# Supabase Configuration
# =====================================================
# Get these from: Supabase Dashboard → Settings → API

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://yourproject.supabase.co

# Supabase anonymous/public key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# =====================================================
# GitHub Staff Picks Integration
# =====================================================
# Configure a public GitHub repository to store staff picks

# GitHub username or organization that owns the favorites repo
NEXT_PUBLIC_GITHUB_OWNER=your-github-username

# Repository name containing favorites.json
NEXT_PUBLIC_GITHUB_REPO=devsnaps-favorites

# Path to favorites.json file (optional, defaults to "favorites.json")
NEXT_PUBLIC_GITHUB_FAVORITES_PATH=favorites.json

# Optional: GitHub Personal Access Token for higher API rate limits
# Without token: 60 requests/hour
# With token: 5,000 requests/hour
# Scopes needed: public_repo (read-only)
# Get from: GitHub Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=your-github-pat-optional

# =====================================================
# Optional: Analytics & Monitoring
# =====================================================
# Add your preferred analytics provider

# Vercel Analytics (automatically enabled on Vercel)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# Google Analytics
# NEXT_PUBLIC_GA_ID=

# Sentry (error tracking)
# NEXT_PUBLIC_SENTRY_DSN=

# =====================================================
# Development Settings
# =====================================================
# Uncomment for development-specific settings

# Node environment
# NODE_ENV=development

# Enable Next.js debug mode
# NEXT_DEBUG=true
